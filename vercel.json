{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "routePrefix": "/_/backend",
      "framework": "fastapi"
    }
  },
  "rewrites": [
    { "source": "/api/v1/:path*", "destination": "/_/backend/:path*" }
  ]
}
